    "    )\n",
    "    scribe_log(\n",
    "        blackboard,\n",
    "        \"DIRECTOR\",\n",
    "        \"depth_extraction_complete\",\n",
    "        f\"Stage 8b depth extraction complete. Signal: '{depth_response[:80]}'\",\n",
    "    )\n",
    "\n",
    "print()\n",
    "print(\"✓ Depth signal captured\")\n",
    "print(f\"✓ Reasoning trace: {len(blackboard['reasoning_trace'])} entries\")"
   ]
