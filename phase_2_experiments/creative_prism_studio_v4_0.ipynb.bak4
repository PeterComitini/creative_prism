    "scribe_log(\n",
    "    blackboard,\n",
    "    \"CRITIC\",\n",
    "    \"evaluation_complete\",\n",
    "    f\"Pass 1 evaluation complete [{CRITIC_PROVIDER}]. Refinement paths identified.\",\n",
    ")\n",
    "validate_stage(blackboard, \"critic\")\n",
    "\n",
    "# Parse RESEARCH_REQUESTs from Creator and Critic for Researcher routing\n",
