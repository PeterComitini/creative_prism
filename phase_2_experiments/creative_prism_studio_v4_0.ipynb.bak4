    "# ── STAGE 9b: RESEARCH APPENDIX ──────────────────────────────────────────────\n",
    "# Prints full research trace as a readable appendix after final synthesis.\n",
    "# All findings surfaced for PIL review. Future: downloadable document.\n",
    "\n",
    "print(\"═\" * 60)\n",
