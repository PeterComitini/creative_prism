    "                \"description\": c.get(\"title\", \"\"),\n",
    "                \"reasoning_summary\": \"\",\n",
    "                \"research_influences\": [],\n",
    "                \"critic_assessment\": {\n",
    "                    \"strengths\": [],\n",
    "                    \"concerns\": [],\n",
    "                    \"refinement_notes\": [],\n",
    "                },\n",
    "            }\n",
    "        )\n",
